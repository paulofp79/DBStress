SQL> select cur.event_name as event,
  2         cur.wait_class,
  3         sum(cur.time_waited_micro - prev.time_waited_micro)/1e6 as time_waited_s,
  4         sum(cur.total_waits - prev.total_waits) as total_waits
  5    from dba_hist_system_event cur
  6    join dba_hist_system_event prev
  7      on cur.dbid = prev.dbid
  8     and cur.instance_number = prev.instance_number
  9     and cur.event_id = prev.event_id
 10     and cur.snap_id = 1839
 11     and prev.snap_id = 1838
 12   where cur.dbid = 1276751934
 13     and cur.event_name not like 'rdbms ipc message%'
 14     and cur.event_name not like 'SQL*Net message from client%'
 15   group by cur.event_name, cur.wait_class
 16   having sum(cur.time_waited_micro - prev.time_waited_micro) > 0
 17   order by time_waited_s desc
 18   fetch first 10 rows only;

